generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                        String          @id @default(uuid()) @db.Uuid
  name                      String          @map("name")
  slug                      String          @unique @map("slug")
  whatsappPhoneNumberId     String?         @map("whatsapp_phone_number_id")
  whatsappBusinessAccountId String?         @map("whatsapp_business_account_id")
  defaultLanguage           String          @default("en") @map("default_language")
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")
  instagramPageId           String?         @map("instagram_page_id")
  usageLogs                 AIUsageLog[]
  conversations             Conversation[]
  customers                 Customer[]
  knowledgeBase             KnowledgeBase[]
  quickReplies              QuickReply[]
  settings                  TenantSettings?
  users                     User[]

  @@map("tenants")
}

model User {
  id                         String         @id @default(uuid()) @db.Uuid
  tenantId                   String         @map("tenant_id") @db.Uuid
  email                      String         @map("email")
  passwordHash               String?        @map("password_hash")
  fullName                   String         @map("full_name")
  role                       String         @default("agent") @map("role")
  preferredLanguage          String         @default("en") @map("preferred_language")
  isOnline                   Boolean        @default(false) @map("is_online")
  isActive                   Boolean        @default(true) @map("is_active")
  maxConcurrentConversations Int            @default(5) @map("max_concurrent_conversations")
  createdAt                  DateTime       @default(now()) @map("created_at")
  suggestions                AISuggestion[]
  conversations              Conversation[] @relation("AssignedAgent")
  conversationReads          ConversationRead[]
  tenant                     Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email], map: "ix_users_tenant_email")
  @@index([tenantId], map: "ix_users_tenant")
  @@map("users")
}

model Customer {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  phone             String         @map("phone")
  name              String?        @map("name")
  email             String?        @map("email")
  socialMedia       String?        @map("social_media")
  tag               String?        @map("tag")
  profilePictureUrl String?        @map("profile_picture_url")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  conversations     Conversation[]
  tenant            Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone], map: "ix_customers_tenant_phone")
  @@map("customers")
}

model Conversation {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  customerId       String    @map("customer_id") @db.Uuid
  assignedAgentId  String?   @map("assigned_agent_id") @db.Uuid
  channel          String    @default("whatsapp") @map("channel")
  status           String    @default("queued") @map("status")
  detectedLanguage String?   @map("detected_language")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  assignedAgent    User?              @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  customer         Customer           @relation(fields: [customerId], references: [id])
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  messages         Message[]
  reads            ConversationRead[]

  @@index([tenantId, status], map: "ix_conversations_tenant_status")
  @@map("conversations")
}

model Message {
  id               String               @id @default(uuid()) @db.Uuid
  conversationId   String               @map("conversation_id") @db.Uuid
  senderType       String               @map("sender_type")
  senderId         String?              @map("sender_id") @db.Uuid
  originalText     String               @map("original_text")
  detectedLanguage String?              @map("detected_language")
  externalId       String?              @map("external_id")
  deletedAt        DateTime?            @map("deleted_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  suggestion       AISuggestion?
  attachments      MessageAttachment[]
  translations     MessageTranslation[]
  conversation     Conversation         @relation(fields: [conversationId], references: [id])

  @@index([conversationId], map: "ix_messages_conversation")
  @@map("messages")
}

model MessageAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  messageId       String   @map("message_id") @db.Uuid
  type            String   @map("type")
  mimeType        String?  @map("mime_type")
  fileName        String?  @map("file_name")
  fileSizeBytes   Int?     @map("file_size_bytes")
  sourceUrl       String?  @map("source_url")
  providerMediaId String?  @map("provider_media_id")
  createdAt       DateTime @default(now()) @map("created_at")
  message         Message  @relation(fields: [messageId], references: [id])

  @@index([messageId], map: "ix_message_attachments_message")
  @@map("message_attachments")
}

model MessageTranslation {
  id             String   @id @default(uuid()) @db.Uuid
  messageId      String   @map("message_id") @db.Uuid
  sourceLanguage String   @map("source_language")
  targetLanguage String   @map("target_language")
  translatedText String   @map("translated_text")
  provider       String   @map("provider")
  createdAt      DateTime @default(now()) @map("created_at")
  message        Message  @relation(fields: [messageId], references: [id])

  @@unique([messageId, targetLanguage], map: "ix_translations_message_target")
  @@map("message_translations")
}

model AISuggestion {
  id                 String   @id @default(uuid()) @db.Uuid
  messageId          String   @unique @map("message_id") @db.Uuid
  agentId            String   @map("agent_id") @db.Uuid
  suggestionText     String   @map("suggestion_text")
  suggestionLanguage String   @map("suggestion_language")
  wasUsed            Boolean  @default(false) @map("was_used")
  finalText          String?  @map("final_text")
  createdAt          DateTime @default(now()) @map("created_at")
  agent              User     @relation(fields: [agentId], references: [id])
  message            Message  @relation(fields: [messageId], references: [id])

  @@map("ai_suggestions")
}

model AIUsageLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  service       String   @map("service")
  model         String?  @map("model")
  inputTokens   Int      @default(0) @map("input_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  estimatedCost Float    @default(0) @map("estimated_cost")
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "ix_usage_log_tenant")
  @@map("ai_usage_logs")
}

model TenantSettings {
  id                        String   @id @default(uuid()) @db.Uuid
  tenantId                  String   @unique @map("tenant_id") @db.Uuid
  openaiApiKey              String?  @map("openai_api_key")
  deeplApiKey               String?  @map("deepl_api_key")
  whatsappApiToken          String?  @map("whatsapp_api_token")
  whatsappVerifyToken       String?  @map("whatsapp_verify_token")
  whatsappPhoneNumberId     String?  @map("whatsapp_phone_number_id")
  whatsappBusinessAccountId String?  @map("whatsapp_business_account_id")
  whatsappProvider          String   @default("evolution") @map("whatsapp_provider")
  whatsappConnected         Boolean  @default(false) @map("whatsapp_connected")
  evolutionInstanceName     String?  @map("evolution_instance_name")
  evolutionInstanceToken    String?  @map("evolution_instance_token")
  evolutionServerUrl        String?  @map("evolution_server_url")
  openaiModel               String   @default("gpt-4.1-mini") @map("openai_model")
  aiTemperature             Float    @default(0.7) @map("ai_temperature")
  aiSystemPrompt            String?  @map("ai_system_prompt")
  aiMaxTokens               Int      @default(200) @map("ai_max_tokens")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  staysnetClientId          String?  @map("staysnet_client_id")
  staysnetClientSecret      String?  @map("staysnet_client_secret")
  staysnetDomain            String?  @map("staysnet_domain")
  instagramPageAccessToken  String?  @map("instagram_page_access_token")
  instagramPageId           String?  @map("instagram_page_id")
  instagramVerifyToken      String?  @map("instagram_verify_token")
  enableAutoResponse        Boolean  @default(false) @map("enable_auto_response")
  autoResponseIntents       String?  @map("auto_response_intents")
  tenant                    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}

model KnowledgeBase {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title     String   @map("title")
  content   String   @map("content")
  category  String   @default("other") @map("category")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, isActive], map: "ix_kb_tenant_active")
  @@map("knowledge_base")
}

model QuickReply {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title     String   @map("title")
  body      String   @map("body")
  shortcut  String?  @map("shortcut")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "ix_quick_replies_tenant")
  @@map("quick_replies")
}

model ConversationRead {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  lastReadAt     DateTime     @default(now()) @map("last_read_at")
  user           User         @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId], map: "ix_conversation_reads_user_conv")
  @@map("conversation_reads")
}

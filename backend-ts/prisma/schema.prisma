generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Tenant {
  id                       String          @id @default(uuid()) @db.Uuid
  name                     String          @map("name")
  slug                     String          @unique @map("slug")
  whatsappPhoneNumberId    String?         @map("whatsapp_phone_number_id")
  whatsappBusinessAccountId String?        @map("whatsapp_business_account_id")
  defaultLanguage          String          @default("en") @map("default_language")
  // ── Billing ──────────────────────────────────────────
  // plan: trial | starter | professional | scale | enterprise
  plan                     String          @default("trial") @map("plan")
  // planStatus: trial | active | past_due | cancelled
  planStatus               String          @default("trial") @map("plan_status")
  trialEndsAt              DateTime?       @map("trial_ends_at")
  stripeCustomerId         String?         @map("stripe_customer_id")
  stripeSubscriptionId     String?         @map("stripe_subscription_id")
  // ── Onboarding ───────────────────────────────────────
  // 0=new 1=whatsapp 2=ai 3=team 4=done
  onboardingStep           Int             @default(0) @map("onboarding_step")
  // ─────────────────────────────────────────────────────
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  instagramPageId          String?         @map("instagram_page_id")
  usageLogs                AIUsageLog[]
  conversations            Conversation[]
  customers                Customer[]
  knowledgeBase            KnowledgeBase[]
  quickReplies             QuickReply[]
  taskQueues               TaskQueue[]
  serviceOrders            ServiceOrder[]
  settings                 TenantSettings?
  users                    User[]

  @@map("tenants")
}

model TaskQueue {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  type           String    @map("type") // e.g. 'checkin', 'checkout'
  status         String    @default("pending") @map("status") // pending, sent, cancelled
  customerPhone  String    @map("customer_phone")
  customerName   String    @map("customer_name")
  reservationId  String    @map("reservation_id")
  scheduledFor   DateTime  @map("scheduled_for")
  messagePayload String    @map("message_payload") // Text draft
  magicToken     String?   @unique @map("magic_token") // UUID token for guest check-in form link
  guestFormData  String?   @map("guest_form_data")   // JSON: submitted guest form (name, doc, photos)
  guestFormAt    DateTime? @map("guest_form_at")     // When guest submitted the form
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant         Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, reservationId, type], map: "ix_taskqueue_unique_task")
  @@index([tenantId, status, scheduledFor], map: "ix_taskqueue_filter")
  @@index([magicToken], map: "ix_taskqueue_magic_token")
  @@map("task_queue")
}

model User {
  id                         String             @id @default(uuid()) @db.Uuid
  tenantId                   String             @map("tenant_id") @db.Uuid
  email                      String             @map("email")
  passwordHash               String?            @map("password_hash")
  fullName                   String             @map("full_name")
  role                       String             @default("agent") @map("role")
  preferredLanguage          String             @default("en") @map("preferred_language")
  isOnline                   Boolean            @default(false) @map("is_online")
  isActive                   Boolean            @default(true) @map("is_active")
  maxConcurrentConversations Int                @default(5) @map("max_concurrent_conversations")
  createdAt                  DateTime           @default(now()) @map("created_at")
  suggestions                AISuggestion[]
  conversations              Conversation[]     @relation("AssignedAgent")
  conversationReads          ConversationRead[]
  pushSubscriptions          PushSubscription[]
  tenant                     Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email], map: "ix_users_tenant_email")
  @@index([tenantId], map: "ix_users_tenant")
  @@map("users")
}

model Customer {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  phone             String         @map("phone")
  name              String?        @map("name")
  email             String?        @map("email")
  socialMedia       String?        @map("social_media")
  tag               String?        @default("GUEST") @map("tag")
  role              String         @default("guest") @map("role") // "guest", "owner", "staff", "lead"
  profilePictureUrl String?        @map("profile_picture_url")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  conversations     Conversation[]
  tenant            Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone], map: "ix_customers_tenant_phone")
  @@map("customers")
}

model Conversation {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  customerId       String             @map("customer_id") @db.Uuid
  assignedAgentId  String?            @map("assigned_agent_id") @db.Uuid
  channel          String             @default("whatsapp") @map("channel")
  status           String             @default("queued") @map("status")
  priority         String             @default("normal") @map("priority")
  detectedLanguage String?            @map("detected_language")
  deletedAt        DateTime?          @map("deleted_at")  // soft-delete: null = active, set = archived
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  assignedAgent    User?              @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  customer         Customer           @relation(fields: [customerId], references: [id])
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  messages         Message[]
  reads            ConversationRead[]
  serviceOrders    ServiceOrder[]

  @@index([tenantId, status], map: "ix_conversations_tenant_status")
  @@map("conversations")
}

model Message {
  id               String               @id @default(uuid()) @db.Uuid
  conversationId   String               @map("conversation_id") @db.Uuid
  senderType       String               @map("sender_type")
  senderId         String?              @map("sender_id") @db.Uuid
  originalText     String               @map("original_text")
  detectedLanguage String?              @map("detected_language")
  externalId       String?              @unique @map("external_id")
  status           String               @default("sent") @map("status")
  deletedAt        DateTime?            @map("deleted_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  suggestion       AISuggestion?
  attachments      MessageAttachment[]
  translations     MessageTranslation[]
  conversation     Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId], map: "ix_messages_conversation")
  @@map("messages")
}

model MessageAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  messageId       String   @map("message_id") @db.Uuid
  type            String   @map("type")
  mimeType        String?  @map("mime_type")
  fileName        String?  @map("file_name")
  fileSizeBytes   Int?     @map("file_size_bytes")
  sourceUrl       String?  @map("source_url")
  providerMediaId String?  @map("provider_media_id")
  createdAt       DateTime @default(now()) @map("created_at")
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId], map: "ix_message_attachments_message")
  @@map("message_attachments")
}

model MessageTranslation {
  id             String   @id @default(uuid()) @db.Uuid
  messageId      String   @map("message_id") @db.Uuid
  sourceLanguage String   @map("source_language")
  targetLanguage String   @map("target_language")
  translatedText String   @map("translated_text")
  provider       String   @map("provider")
  createdAt      DateTime @default(now()) @map("created_at")
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, targetLanguage], map: "ix_translations_message_target")
  @@map("message_translations")
}

model AISuggestion {
  id                 String   @id @default(uuid()) @db.Uuid
  messageId          String   @unique @map("message_id") @db.Uuid
  agentId            String   @map("agent_id") @db.Uuid
  suggestionText     String   @map("suggestion_text")
  suggestionLanguage String   @map("suggestion_language")
  wasUsed            Boolean  @default(false) @map("was_used")
  finalText          String?  @map("final_text")
  createdAt          DateTime @default(now()) @map("created_at")
  agent              User     @relation(fields: [agentId], references: [id])
  message            Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("ai_suggestions")
}

model AIUsageLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  service       String   @map("service")
  model         String?  @map("model")
  inputTokens   Int      @default(0) @map("input_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  estimatedCost Float    @default(0) @map("estimated_cost")
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "ix_usage_log_tenant")
  @@map("ai_usage_logs")
}

model TenantSettings {
  id                        String   @id @default(uuid()) @db.Uuid
  tenantId                  String   @unique @map("tenant_id") @db.Uuid
  openaiApiKey              String?  @map("openai_api_key")
  deeplApiKey               String?  @map("deepl_api_key")
  whatsappApiToken          String?  @map("whatsapp_api_token")
  whatsappVerifyToken       String?  @map("whatsapp_verify_token")
  whatsappPhoneNumberId     String?  @map("whatsapp_phone_number_id")
  whatsappBusinessAccountId String?  @map("whatsapp_business_account_id")
  whatsappProvider          String   @default("evolution") @map("whatsapp_provider")
  whatsappConnected         Boolean  @default(false) @map("whatsapp_connected")
  evolutionInstanceName     String?  @map("evolution_instance_name")
  evolutionInstanceToken    String?  @map("evolution_instance_token")
  evolutionServerUrl        String?  @map("evolution_server_url")
  openaiModel               String   @default("gpt-4.1-mini") @map("openai_model")
  aiTemperature             Float    @default(0.7) @map("ai_temperature")
  aiSystemPrompt            String?  @map("ai_system_prompt")
  aiMaxTokens               Int      @default(200) @map("ai_max_tokens")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  staysnetClientId          String?  @map("staysnet_client_id")
  staysnetClientSecret      String?  @map("staysnet_client_secret")
  staysnetDomain            String?  @map("staysnet_domain")
  instagramPageAccessToken  String?  @map("instagram_page_access_token")
  instagramPageId           String?  @map("instagram_page_id")
  instagramVerifyToken      String?  @map("instagram_verify_token")
  enableAutoResponse        Boolean   @default(false) @map("enable_auto_response")
  autoResponseIntents       String?   @map("auto_response_intents")
  timezone                  String    @default("America/Sao_Paulo") @map("timezone") // IANA timezone for task date calculations
  lastTaskSyncAt            DateTime? @map("last_task_sync_at")
  vapidPublicKey            String?   @map("vapid_public_key")
  vapidPrivateKey           String?   @map("vapid_private_key")
  tenant                    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  endpoint  String   @map("endpoint")
  p256dh    String   @map("p256dh")
  auth      String   @map("auth")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint], map: "ix_push_sub_user_endpoint")
  @@index([tenantId], map: "ix_push_sub_tenant")
  @@map("push_subscriptions")
}

model KnowledgeBase {
  id        String                       @id @default(uuid()) @db.Uuid
  tenantId  String                       @map("tenant_id") @db.Uuid
  title     String                       @map("title")
  content   String                       @map("content")
  category  String                       @default("other") @map("category")
  isActive  Boolean                      @default(true) @map("is_active")
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")
  tenant    Tenant                       @relation(fields: [tenantId], references: [id])
  embedding Unsupported("vector(1536)")?

  @@index([tenantId, isActive], map: "ix_kb_tenant_active")
  @@map("knowledge_base")
}

model QuickReply {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title     String   @map("title")
  body      String   @map("body")
  shortcut  String?  @map("shortcut")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "ix_quick_replies_tenant")
  @@map("quick_replies")
}

model ConversationRead {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  lastReadAt     DateTime     @default(now()) @map("last_read_at")
  user           User         @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId], map: "ix_conversation_reads_user_conv")
  @@map("conversation_reads")
}

model ServiceOrder {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  conversationId     String?       @map("conversation_id") @db.Uuid
  sequentialNumber   Int           @map("sequential_number")

  // Identification
  location           String        @map("location")
  origin             String?       @map("origin")              // hóspede | proprietário | limpeza | vistoria | equipe_interna

  // Type
  category           String?       @map("category")            // limpeza | manutenção | vistoria | enxoval | check-in | check-out | suporte | reposição | emergência | outro
  subcategory        String?       @map("subcategory")
  description        String        @map("description")
  priority           String        @default("medium") @map("priority") // low | medium | high | urgent

  // Impact
  impactOnStay       String?       @map("impact_on_stay")      // none | partial | blocks_checkin
  guestName          String?       @map("guest_name")
  reservationCode    String?       @map("reservation_code")
  paymentResponsible String?       @map("payment_responsible") // guest | vivare | owner

  // Responsible
  assignedTo         String?       @map("assigned_to")

  // Planning
  dueDate            DateTime?     @map("due_date")

  // Execution
  startedAt          DateTime?     @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  notes              String?       @map("notes")
  problems           String?       @map("problems")

  // Status & timestamps
  status             String        @default("pending") @map("status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  conversation       Conversation? @relation(fields: [conversationId], references: [id])

  @@index([tenantId, status], map: "ix_service_orders_tenant_status")
  @@map("service_orders")
}
